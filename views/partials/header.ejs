<header class="app-header">
  <div class="header-left">
    <a href="/dashboard" class="header-brand">SisFactura</a>
    <nav class="nav-tabs">
      <a href="/dashboard"  class="nav-tab <%= titulo==='Dashboard'  ? 'active':'' %>">Dashboard</a>
      <% if (permisosUser.includes('ver_facturas')) { %>
        <a href="/facturas"  class="nav-tab <%= titulo==='Facturas'  ? 'active':'' %>">Facturas</a>
        <a href="/conceptos" class="nav-tab <%= titulo==='Conceptos' ? 'active':'' %>">Conceptos</a>
        <a href="/reportes"  class="nav-tab <%= titulo==='Reportes'  ? 'active':'' %>">Reportes</a>
      <% } %>
      <% if (permisosUser.includes('gestionar_usuarios')) { %>
        <a href="/usuarios" class="nav-tab <%= titulo==='Usuarios' ? 'active':'' %>">Usuarios</a>
      <% } %>
    </nav>
  </div>
  <div class="header-right">
    <div class="user-badge">
      <span class="name"><%= usuario.nombreCompleto %></span>
      <span class="role role-<%= usuario.rol %>">
        <% if (usuario.rol === 'admin') { %>Administrador
        <% } else if (usuario.rol === 'privileged') { %>Privilegiado
        <% } else { %>Visor<% } %>
      </span>
    </div>
    <form action="/logout" method="POST" style="margin:0">
      <button type="submit" class="btn-logout">Salir</button>
    </form>
  </div>
</header>

<% if (messages.success && messages.success.length) { %>
  <div class="flash flash-success"><%= messages.success[0] %></div>
<% } %>
<% if (messages.error && messages.error.length) { %>
  <div class="flash flash-error"><%= messages.error[0] %></div>
<% } %>
