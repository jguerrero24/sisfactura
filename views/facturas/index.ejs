<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Facturas — SisFactura</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('../partials/header') %>
<main class="app-content">
  <div class="card">
    <div class="card-title">
      Gestión de Facturas
      <% if (permisosUser.includes('crear_factura')) { %>
        <a href="/facturas/nueva" class="btn btn-accent btn-sm">+ Nueva Factura</a>
      <% } %>
    </div>

    <% if (!facturas || facturas.length === 0) { %>
      <div class="empty-state"><div class="icon">🧾</div><div class="msg">No hay facturas registradas</div></div>
    <% } else { %>
      <% facturas.forEach(function(f) { %>
        <div class="invoice-list-item">
          <div>
            <div class="inv-list-id"><%= f.numeroFactura %></div>
            <div class="inv-list-meta">
              <%= f.nombreComprador %> &middot; Recibe: <%= f.nombreVendedor %> &middot; <%= f.fecha %>
              <% if (f.anulada) { %><span class="badge" style="background:rgba(224,85,85,.15);color:var(--danger);margin-left:8px;">ANULADA</span><% } %>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <div class="inv-list-amount">&#x20A1;<%= parseFloat(f.total).toFixed(2) %></div>
            <div class="inv-list-actions">
              <a href="/facturas/<%= f._id %>" class="btn btn-ghost btn-sm">Ver</a>
              <% if (permisosUser.includes('imprimir_factura')) { %>
                <a href="/facturas/<%= f._id %>?imprimir=1" target="_blank" class="btn btn-accent btn-sm">Imprimir</a>
              <% } %>
              <% if (permisosUser.includes('gestionar_usuarios') && !f.anulada) { %>
                <form action="/facturas/<%= f._id %>/anular" method="POST" style="display:inline"
                      onsubmit="return confirm('¿Anular la factura <%= f.numeroFactura %>?')">
                  <button type="submit" class="btn btn-danger btn-sm">Anular</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>

      <div style="display:flex;gap:8px;justify-content:center;margin-top:20px;padding-top:16px;border-top:1px solid var(--border);">
        <% if (pagina > 1) { %><a href="?pagina=<%= pagina-1 %>" class="btn btn-ghost btn-sm">← Anterior</a><% } %>
        <span style="font-size:12px;color:var(--text-muted);align-self:center;">Página <%= pagina %></span>
        <% if (facturas.length === 20) { %><a href="?pagina=<%= pagina+1 %>" class="btn btn-ghost btn-sm">Siguiente →</a><% } %>
      </div>
    <% } %>
  </div>
</main>
<script src="/js/main.js"></script>
</body>
</html>
